# StudyMate AI - Environment Variables Example

# OpenAI API Key (Required for live AI features. If omitted, app uses high-fidelity local mock engine fallback)
OPENAI_API_KEY=

# Supabase Configurations (Required for live vector storage. If omitted, app uses active localStorage adapter)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
